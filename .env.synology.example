# Copy this file to ".env" on the Synology NAS next to docker-compose.yml.
# Do not commit the real .env file.

# The public website origin that is allowed to connect to the multiplayer server.
ALLOWED_ORIGINS=https://wuland.bekulov.com

# Local NAS/LAN port exposed by Docker. Cloudflare Tunnel can still reach the
# container internally even if you do not use this LAN port publicly.
WULAND_SERVER_PORT=2567

# Sleeping/offline players stay visible for this many hours.
OFFLINE_PLAYER_TTL_HOURS=168

# Set to true only when you intentionally want to wipe sleeping/offline players
# from server/data/wuland-players.json on the next server startup.
CLEAR_PLAYER_STORE_ON_START=false

# Set to true to freeze enemy AI movement/chasing/contact damage while keeping
# enemies visible and attackable.
ENEMY_AI_PAUSED=false

# Paste the token Cloudflare gives you when you create a Docker tunnel.
CLOUDFLARE_TUNNEL_TOKEN=replace_with_your_cloudflare_tunnel_token
